{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "node.KHR_audio_emitter.schema.json",
    "title": "KHR_audio_emitter glTF Node Extension",
    "type": "object",
    "description": "Node extension that references audio emitters.",
    "allOf": [{ "$ref": "glTFProperty.schema.json" }],
    "properties": {
        "emitters": {
            "type": "array",
            "description": "The indices of each audio emitter referenced by this node.",
            "items": {
                "allOf": [ { "$ref": "glTFid.schema.json" } ]
            },
            "uniqueItems": true,
            "minItems": 1
        },
        "extensions": {},
        "extras": {}
    },
    "required": ["emitters"]
}

{
    "$schema": "http://json-schema.org/draft-04/schema",
    "title": "KHR_audio_emitter glTF Node Extension",
    "type": "object",
    "allOf": [{ "$ref": "glTFProperty.schema.json" }],
    "properties": {
        "emitters": {
            "type": "array",
            "description": "The ids of the audio emitters referenced by this node.",
            "items": {
                "$ref": "glTFid.schema.json"
            },
            "uniqueItems": true,
            "minItems": 1
        },
        "emitter": {
            "description": "Deprecated legacy single-emitter form. Use `emitters` instead.",
            "allOf": [{ "$ref": "glTFid.schema.json" }]
        },
        "extensions": {},
        "extras": {}
    },
    "oneOf": [
        {
            "required": ["emitters"],
            "not": {
                "required": ["emitter"]
            }
        },
        {
            "required": ["emitter"],
            "not": {
                "required": ["emitters"]
            }
        }
    ]
}

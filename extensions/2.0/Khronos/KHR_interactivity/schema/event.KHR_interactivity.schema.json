{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "event.KHR_interactivity.schema.json",
    "title": "Behavior graph event",
    "type": "object",
    "allOf": [ { "$ref": "glTFProperty.schema.json" } ],
    "properties": {
        "id": {
            "title": "The event id.",
            "type": "string"
        },
        "values": {
            "title": "The event value sockets.",
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "allOf": [ { "$ref": "glTFProperty.schema.json" } ],
                "properties": {
                    "type": {
                        "title": "The type index.",
                        "allOf": [ { "$ref": "glTFid.schema.json" } ]
                    },
                    "value": {
                        "title": "The initial value.",
                        "type": "array",
                        "minItems": 1
                    },
                    "extensions": { },
                    "extras": { }
                },
                "required": [ "type" ]
            },
            "minProperties": 1,
            "not": { "required": [ "event" ] }
        },
        "extensions": { },
        "extras": { }
    }
}